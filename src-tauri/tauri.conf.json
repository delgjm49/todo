{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Todo",
  "version": "0.1.0",
  "identifier": "com.todo.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Todo",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "minWidth": 1280,
        "minHeight": 800
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "icon": ["icons/icon.ico"]
  }
}
