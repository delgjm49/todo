{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Todo",
  "version": "0.1.0",
  "identifier": "com.todoapp.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Todo App",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "decorations": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "publisher": "Todo App",
    "copyright": "Copyright (c) 2026. All rights reserved.",
    "icon": ["icons/icon.png"]
  }
}
